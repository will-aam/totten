generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  appointments      Appointment[]
  categories        Category[]
  check_ins         CheckIn[]
  clients           Client[]
  payment_methods   OrganizationPaymentMethod[]
  transactions      Transaction[]
  link_bio          LinkBio?
  message_templates MessageTemplate[]
  package_templates PackageTemplate[]
  packages          Package[]
  service_durations ServiceDuration[]
  services          Service[]
  settings          Settings?
  admins            Admin[]           @relation("AdminToOrganization")

  @@map("organizations")
}

model Admin {
  id                 String         @id @default(cuid())
  display_name       String?
  email              String         @unique
  password           String
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  email_verified     Boolean        @default(false)
  reset_token        String?        @unique
  verification_token String?        @unique
  organizations      Organization[] @relation("AdminToOrganization")

  @@map("admins")
}

model Settings {
  id               String       @id @default(cuid())
  company_name     String
  document         String?
  responsible_name String?
  phone_landline   String?
  phone_whatsapp   String
  email_admin      String?
  opening_time     String       @default("08:00")
  closing_time     String       @default("19:00")
  organization_id  String       @unique
  updated_at       DateTime     @updatedAt
  trade_name       String?
  organization     Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("settings")
}

model MessageTemplate {
  id              String       @id @default(cuid())
  type            String
  content         String
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([type, organization_id])
  @@map("message_templates")
}

model LinkBio {
  id                String       @id @default(cuid())
  profile_image_url String?
  bio_text          String?
  theme_color_light String       @default("#ffffff")
  theme_color_dark  String       @default("#000000")
  font_family       String       @default("Inter")
  social_links      Json?
  organization_id   String       @unique
  organization      Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("link_bio")
}

model Client {
  id              String        @id @default(cuid())
  name            String
  cpf             String
  phone_whatsapp  String
  email           String?
  birth_date      DateTime?
  zip_code        String?
  city            String?
  street          String?
  number          String?
  organization_id String
  active          Boolean       @default(true) // 🔥 Adicione APENAS esta linha
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  appointments    Appointment[]
  check_ins       CheckIn[]
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  packages        Package[]
  transactions      Transaction[]

  @@unique([cpf, organization_id])
  @@map("clients")
}

model Category {
  id              String       @id @default(cuid())
  name            String
  organization_id String
  active          Boolean      @default(true)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  services        Service[]

  @@map("categories")
}

model Service {
  id                String            @id @default(cuid())
  name              String
  description       String?
  duration          Int
  price             Decimal           @db.Decimal(10, 2)
  material_cost     Decimal?          @db.Decimal(10, 2) // 🔥 NOVA COLUNA ADICIONADA AQUI
  category_id       String
  organization_id   String
  active            Boolean           @default(true)
  appointments      Appointment[]
  package_templates PackageTemplate[]
  packages          Package[]
  category          Category          @relation(fields: [category_id], references: [id])
  organization      Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("services")
}

model PackageTemplate {
  id              String       @id @default(cuid())
  name            String
  description     String?
  total_sessions  Int
  price           Decimal
  active          Boolean      @default(true)
  organization_id String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  service_id      String
  validity_days   Int?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  service         Service      @relation(fields: [service_id], references: [id])

  @@map("package_templates")
}

model Package {
  id              String        @id @default(cuid())
  name            String
  total_sessions  Int
  used_sessions   Int           @default(0)
  price           Decimal
  active          Boolean       @default(true)
  client_id       String
  service_id      String
  organization_id String
  transactions      Transaction[]
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  appointments    Appointment[]
  check_ins       CheckIn[]
  client          Client        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  service         Service       @relation(fields: [service_id], references: [id])
  vouchers        Voucher[]

  @@map("packages")
}

model Voucher {
  id         String   @id @default(cuid())
  issue_date DateTime @default(now())
  image_url  String?
  package_id String
  package    Package  @relation(fields: [package_id], references: [id], onDelete: Cascade)

  @@map("vouchers")
}

model Appointment {
  id              String            @id @default(cuid())
  date_time       DateTime
  status          AppointmentStatus @default(PENDENTE)
  payment_method  PaymentMethod?
  has_charge      Boolean           @default(false)
  session_number  Int?
  observations    String?
  recurrence_id  String?
  client_id       String
  service_id      String
  package_id      String?
  organization_id String
  transaction       Transaction?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  client          Client            @relation(fields: [client_id], references: [id], onDelete: Cascade)
  organization    Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  package         Package?          @relation(fields: [package_id], references: [id])
  service         Service           @relation(fields: [service_id], references: [id])
  check_in        CheckIn?


@@index([organization_id, date_time])
  @@index([client_id, date_time])
  @@index([recurrence_id])
  @@map("appointments")
}

model ServiceDuration {
  id              String       @id @default(cuid())
  label           String
  minutes         Int
  is_active       Boolean      @default(true)
  display_order   Int          @default(0)
  organization_id String
  created_at      DateTime     @default(now())
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, minutes])
  @@map("service_durations")
}

model CheckIn {
  id              String       @id @default(cuid())
  date_time       DateTime     @default(now())
  appointment_id  String?      @unique
  client_id       String?
  package_id      String?
  organization_id String
  appointment     Appointment? @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  client          Client?      @relation(fields: [client_id], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  package         Package?     @relation(fields: [package_id], references: [id], onDelete: Cascade)

  @@index([organization_id, date_time])
  @@map("check_ins")
}

enum AppointmentStatus {
  PENDENTE
  CONFIRMADO
  REALIZADO
  CANCELADO
}

enum PaymentMethod {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  OUTRO
}

enum TransactionType {
  RECEITA
  DESPESA
}

enum TransactionStatus {
  PAGO
  PENDENTE
  ATRASADO
}

// Tabela de Meios de Pagamento da Organização
model OrganizationPaymentMethod {
  id              String        @id @default(cuid())
  name            String
  type            PaymentMethod // Usa o seu Enum existente!
  isActive        Boolean       @default(true)
  feePercentage   Decimal       @default(0) @db.Decimal(10, 2)
  feeFixed        Decimal       @default(0) @db.Decimal(10, 2)
  daysToReceive   Int           @default(0)
  organization_id String
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@index([organization_id])
  @@map("organization_payment_methods")
}

// Tabela de Transações (Receitas e Despesas)
model Transaction {
  id                String            @id @default(cuid())
  type              TransactionType
  description       String
  amount            Decimal           @db.Decimal(10, 2)
  date              DateTime
  status            TransactionStatus @default(PAGO)
  
  // 🔥 NOVOS CAMPOS PARA RECORRÊNCIA E PARCELAMENTO (Opcionais)
  recurrence_id     String?           // ID único que agrupa todas as parcelas da mesma conta
  installment       String?           // Ex: "1/12", "2/12" ou "Fixo" para contínuas

  // Relações opcionais (Para sabermos de onde veio o dinheiro)
  client_id         String?
  payment_method_id String?
  appointment_id    String?           @unique // 1 agendamento = 1 transação principal
  package_id        String?

  organization_id   String

  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  client            Client?                    @relation(fields: [client_id], references: [id], onDelete: SetNull)
  payment_method    OrganizationPaymentMethod? @relation(fields: [payment_method_id], references: [id], onDelete: SetNull)
  appointment       Appointment?               @relation(fields: [appointment_id], references: [id], onDelete: SetNull)
  package           Package?                   @relation(fields: [package_id], references: [id], onDelete: SetNull)
  organization      Organization               @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, date])
  @@index([recurrence_id]) // 🔥 Novo índice: deixa a busca por parcelas muito mais rápida
  @@map("transactions")
}